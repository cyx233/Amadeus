# === Auth (provide at least one) ===
# Option 1: Anthropic API key (simplest)
ANTHROPIC_API_KEY=

# Option 2: Claude.ai OAuth token (subscribers)
CLAUDE_CODE_OAUTH_TOKEN=

# Option 3: AWS Bedrock (also use docker-compose.bedrock.yml)
AWS_PROFILE=
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# === LightRAG (optional) ===
EMBEDDING_MODEL=text-embedding-3-small
LLM_MODEL=claude-sonnet-4-20250514

# === Watchdog (optional) ===
WATCHDOG_POLL_MS=15000
WATCHDOG_STALL_MS=300000
