# === Gateway (multi-user) ===
# Shared secret the auth-gateway signs login cookies with and every backend
# verifies. Also derives the key that encrypts stored git/service tokens, so
# rotating it makes previously-encrypted tokens undecryptable (users just
# re-enter them). REQUIRED. Generate one with: openssl rand -hex 32
JWT_SECRET=

# Admin token authorizing account creation (scripts/user.sh presents it).
# Registration via the public login page is disabled; only user.sh can create
# accounts. REQUIRED. Generate one with: openssl rand -hex 32
AMADEUS_ADMIN_TOKEN=

# === Auth (provide at least one) ===
# Option 1: Anthropic API key (simplest)
ANTHROPIC_API_KEY=

# Option 2: Claude.ai OAuth token (subscribers)
CLAUDE_CODE_OAUTH_TOKEN=

# Option 3: AWS Bedrock
AWS_PROFILE=
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
